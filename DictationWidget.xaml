<Window x:Class="VoxPilot.DictationWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoxPilot dictation status" Width="304" Height="82"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" ShowActivated="False"
        Focusable="False" Topmost="True" SourceInitialized="Window_SourceInitialized">
    <Border x:Name="WidgetShell" Margin="10" CornerRadius="19" BorderThickness="1" BorderBrush="#42485B">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F51B1E29" Offset="0" />
                <GradientStop Color="#F511131A" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="22" ShadowDepth="6" Opacity="0.58" />
        </Border.Effect>
        <Grid Margin="12,9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="82" />
            </Grid.ColumnDefinitions>

            <Border x:Name="WidgetIcon" Width="38" Height="38" CornerRadius="19" Background="#7C5CFC"
                    HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock x:Name="WidgetGlyph" Text="&#xE720;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           Foreground="White" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,8,0">
                <TextBlock x:Name="WidgetTitle" Text="Listening…" FontFamily="Segoe UI Variable Text, Segoe UI"
                           FontSize="13" FontWeight="SemiBold" Foreground="#F7F8FB" />
                <TextBlock x:Name="WidgetHint" Text="Speak naturally" Margin="0,3,0,0"
                           FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="10" Foreground="#9097A9"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <StackPanel x:Name="WidgetWave" Grid.Column="2" Orientation="Horizontal" Height="30"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <Rectangle Width="3" Height="5" RadiusX="2" Fill="#8D74FF" Margin="0,0,4,0" VerticalAlignment="Center" />
                <Rectangle Width="3" Height="9" RadiusX="2" Fill="#A28FFF" Margin="0,0,4,0" VerticalAlignment="Center" />
                <Rectangle Width="3" Height="14" RadiusX="2" Fill="#B7A9FF" Margin="0,0,4,0" VerticalAlignment="Center" />
                <Rectangle Width="3" Height="20" RadiusX="2" Fill="#FFFFFF" Margin="0,0,4,0" VerticalAlignment="Center" />
                <Rectangle Width="3" Height="12" RadiusX="2" Fill="#B7A9FF" Margin="0,0,4,0" VerticalAlignment="Center" />
                <Rectangle Width="3" Height="8" RadiusX="2" Fill="#A28FFF" Margin="0,0,4,0" VerticalAlignment="Center" />
                <Rectangle Width="3" Height="5" RadiusX="2" Fill="#8D74FF" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
