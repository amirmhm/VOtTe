<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>VoxPilot</AssemblyName>
    <RootNamespace>VoxPilot</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\VoxPilot.ico</ApplicationIcon>
    <Platforms>AnyCPU;x64</Platforms>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.2.1" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Assets\VoxPilot.ico" />
    <Resource Include="Assets\VoxPilot.ico" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="work\**\*.cs" />
    <EmbeddedResource Remove="work\**\*" />
  </ItemGroup>
</Project>
